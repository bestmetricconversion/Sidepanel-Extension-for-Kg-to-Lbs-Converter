{
  "manifest_version": 3,
  "name": "KG to LBS Converter Chatbot & Custom PDF",
  "version": "1.0.0",
  "description": "A fast KG to LBS and LBS to KG converter with side panel chatbot, history, install page and uninstall feedback.",
  "permissions": ["sidePanel", "storage", "tabs"],
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "action": {
    "default_title": "KG to LBS Converter"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
